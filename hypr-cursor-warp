#!/usr/bin/env python3
"""
hypr-cursor-warp: proportional cursor crossing between hyprland monitors

modes:
  - live cross (on): when cursor naturally crosses to a neighbor monitor,
    snap its y to the proportional position (40% in -> 40% out)
  - dead zone (on): if cursor stuck against a monitor edge with no neighbor
    at that y, warp to the touching neighbor at the proportional y
  - inf canvas (off): user-defined edge teleports between non-adjacent
    monitors. mappings are bidirectional and only fire when the cursor is
    stuck against the configured edge with no natural neighbor available.

env vars:
  HYPR_WARP_LIVE=0          disable live crossing mode
  HYPR_WARP_DEAD=0          disable dead-zone warp mode
  HYPR_WARP_HZ=120          poll rate
  HYPR_WARP_DEBUG=1         verbose logs
  HYPR_WARP_INF_CANVAS=...  enable inf-canvas teleports. format:
                            "MON:edge=MON:edge,..." with edges in
                            {top,bottom,left,right}. example:
                            "DP-4:bottom=eDP-2:top,DP-4:left=DP-3:right"
"""

import json
import os
import socket
import sys
import threading
import time
from dataclasses import dataclass


SIG = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE")
if not SIG:
    print("HYPRLAND_INSTANCE_SIGNATURE not set; is hyprland running?", file=sys.stderr)
    sys.exit(1)

RUNTIME = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
CMD_SOCK = f"{RUNTIME}/hypr/{SIG}/.socket.sock"
EVT_SOCK = f"{RUNTIME}/hypr/{SIG}/.socket2.sock"

LIVE_MODE = os.environ.get("HYPR_WARP_LIVE", "1") != "0"
DEAD_MODE = os.environ.get("HYPR_WARP_DEAD", "1") != "0"
POLL_HZ = int(os.environ.get("HYPR_WARP_HZ", "120"))
DEBUG = os.environ.get("HYPR_WARP_DEBUG", "0") != "0"
INF_CANVAS_RAW = os.environ.get("HYPR_WARP_INF_CANVAS", "").strip()

STUCK_FRAMES = max(4, POLL_HZ // 5)   # ~200ms before dead-zone warp
WARP_COOLDOWN_S = 0.25
EDGE_EPS = 1
EDGE_INSET = EDGE_EPS + 1              # land outside the at-edge zone to
                                       # avoid inf-canvas warp loops
Y_SNAP_MIN = 3                         # don't warp on tiny y deltas
EDGE_NAMES = ("top", "bottom", "left", "right")


def parse_inf_canvas(spec):
    """parse 'MON:edge=MON:edge,...' into a bidirectional dict
    {(mon, edge): (mon, edge)}."""
    result = {}
    if not spec:
        return result
    for entry in spec.split(","):
        entry = entry.strip()
        if not entry:
            continue
        if "=" not in entry:
            print(f"inf-canvas: skip malformed '{entry}' (missing '=')",
                  file=sys.stderr)
            continue
        a, b = entry.split("=", 1)
        try:
            a_mon, a_edge = a.rsplit(":", 1)
            b_mon, b_edge = b.rsplit(":", 1)
        except ValueError:
            print(f"inf-canvas: skip malformed '{entry}' (need 'MON:edge')",
                  file=sys.stderr)
            continue
        a_mon, a_edge = a_mon.strip(), a_edge.strip().lower()
        b_mon, b_edge = b_mon.strip(), b_edge.strip().lower()
        if a_edge not in EDGE_NAMES or b_edge not in EDGE_NAMES:
            print(f"inf-canvas: skip '{entry}' (edge must be one of "
                  f"{EDGE_NAMES})", file=sys.stderr)
            continue
        result[(a_mon, a_edge)] = (b_mon, b_edge)
        result[(b_mon, b_edge)] = (a_mon, a_edge)
    return result


INF_CANVAS = parse_inf_canvas(INF_CANVAS_RAW)


@dataclass
class Monitor:
    name: str
    x: int
    y: int
    w: int
    h: int


def log(*a):
    if DEBUG:
        print(*a, flush=True)


def hypr_send(cmd: str) -> str:
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
        s.connect(CMD_SOCK)
        s.sendall(cmd.encode())
        out = bytearray()
        while True:
            c = s.recv(4096)
            if not c:
                break
            out += c
        return out.decode()


def fetch_monitors():
    mons = []
    for m in json.loads(hypr_send("j/monitors")):
        if m.get("disabled"):
            continue
        w, h = m["width"], m["height"]
        # transforms 1/3/5/7 rotate by 90deg, swapping effective dimensions
        if m.get("transform", 0) % 2 == 1:
            w, h = h, w
        mons.append(Monitor(m["name"], m["x"], m["y"], w, h))
    return mons


def fetch_cursor():
    raw = hypr_send("cursorpos").strip()
    if "," not in raw:
        return None
    try:
        x, y = raw.split(",")
        return int(x.strip()), int(y.strip())
    except ValueError:
        return None


def find_monitor(mons, x, y):
    for m in mons:
        if m.x <= x < m.x + m.w and m.y <= y < m.y + m.h:
            return m
    return None


def left_neighbor(mons, m):
    for n in mons:
        if n is not m and n.x + n.w == m.x:
            return n
    return None


def right_neighbor(mons, m):
    for n in mons:
        if n is not m and n.x == m.x + m.w:
            return n
    return None


def find_monitor_by_name(mons, name):
    for m in mons:
        if m.name == name:
            return m
    return None


def at_edge(m, cx, cy):
    """which edge of m the cursor is touching, or None."""
    if cx <= m.x + EDGE_EPS:
        return "left"
    if cx >= m.x + m.w - 1 - EDGE_EPS:
        return "right"
    if cy <= m.y + EDGE_EPS:
        return "top"
    if cy >= m.y + m.h - 1 - EDGE_EPS:
        return "bottom"
    return None


def perp_rel(m, cx, cy, edge):
    """relative position along the axis perpendicular to `edge`, in [0,1]."""
    if edge in ("left", "right"):
        return (cy - m.y) / m.h
    return (cx - m.x) / m.w


def edge_target(n, edge, rel):
    """coords on monitor n along its `edge`, with perpendicular `rel` (0..1).
    insets by EDGE_INSET px from the destination edge so the cursor lands
    outside the at-edge detection zone, preventing inf-canvas warp loops."""
    if edge == "left":
        tx, ty = n.x + EDGE_INSET, int(round(n.y + rel * n.h))
    elif edge == "right":
        tx, ty = n.x + n.w - 1 - EDGE_INSET, int(round(n.y + rel * n.h))
    elif edge == "top":
        tx, ty = int(round(n.x + rel * n.w)), n.y + EDGE_INSET
    else:  # bottom
        tx, ty = int(round(n.x + rel * n.w)), n.y + n.h - 1 - EDGE_INSET
    tx = max(n.x, min(n.x + n.w - 1, tx))
    ty = max(n.y, min(n.y + n.h - 1, ty))
    return tx, ty


def event_thread(state):
    interest = {"monitoradded", "monitoraddedv2", "monitorremoved",
                "monitorremovedv2", "configreloaded"}
    while True:
        try:
            with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
                s.connect(EVT_SOCK)
                buf = b""
                while True:
                    c = s.recv(4096)
                    if not c:
                        break
                    buf += c
                    while b"\n" in buf:
                        line, buf = buf.split(b"\n", 1)
                        evt = line.decode().split(">>", 1)[0]
                        if evt in interest:
                            try:
                                state["mons"] = fetch_monitors()
                                print(f"layout reload: " + ", ".join(
                                    f"{m.name} {m.w}x{m.h}@{m.x},{m.y}"
                                    for m in state["mons"]), flush=True)
                            except Exception as e:
                                print(f"reload failed: {e}", flush=True)
        except Exception as e:
            print(f"event socket error: {e}; retry in 1s", flush=True)
            time.sleep(1)


def main():
    state = {"mons": fetch_monitors()}
    print(f"hypr-cursor-warp running (live={LIVE_MODE} dead={DEAD_MODE} "
          f"inf={bool(INF_CANVAS)} hz={POLL_HZ})", flush=True)
    for m in state["mons"]:
        print(f"  {m.name}: {m.w}x{m.h} at {m.x},{m.y}", flush=True)
    if INF_CANVAS:
        seen = set()
        for (a_mon, a_edge), (b_mon, b_edge) in INF_CANVAS.items():
            key = tuple(sorted([(a_mon, a_edge), (b_mon, b_edge)]))
            if key in seen:
                continue
            seen.add(key)
            print(f"  inf-canvas: {a_mon}:{a_edge} <-> {b_mon}:{b_edge}",
                  flush=True)

    threading.Thread(target=event_thread, args=(state,), daemon=True).start()

    dt = 1.0 / POLL_HZ
    prev_mon = None
    prev_rel_y = None
    prev_edge_pin = None    # (mon_name, edge) currently being held against
    edge_stuck = 0
    last_warp = 0.0

    while True:
        time.sleep(dt)
        try:
            pos = fetch_cursor()
        except Exception as e:
            log(f"cursor read failed: {e}")
            time.sleep(0.5)
            continue
        if pos is None:
            continue

        cx, cy = pos
        mons = state["mons"]
        m = find_monitor(mons, cx, cy)
        now = time.time()
        cooldown = (now - last_warp) < WARP_COOLDOWN_S

        if m is None:
            prev_mon = None
            prev_rel_y = None
            prev_edge_pin = None
            edge_stuck = 0
            continue

        # 1) live cross: detect monitor change since last poll
        if (LIVE_MODE and not cooldown and prev_mon is not None
                and prev_mon.name != m.name and prev_rel_y is not None):
            target_y = int(round(m.y + prev_rel_y * m.h))
            target_y = max(m.y, min(m.y + m.h - 1, target_y))
            if abs(target_y - cy) >= Y_SNAP_MIN:
                hypr_send(f"dispatch movecursor {cx} {target_y}")
                log(f"cross {prev_mon.name}->{m.name} rel={prev_rel_y:.2f}: "
                    f"y {cy} -> {target_y}")
                last_warp = now
                cy = target_y

        # 2) dead-zone warp: cursor pinned against an edge for STUCK_FRAMES.
        # tracks edge contact (not exact position) so a real mouse held
        # against an edge - which jitters along the parallel axis - still
        # qualifies as stuck. exact-position tracking failed for mice but
        # worked for keyboard mouse-emulation that stops between keypresses.
        edge_now = at_edge(m, cx, cy)
        pin_now = (m.name, edge_now) if edge_now else None
        if pin_now is not None and pin_now == prev_edge_pin:
            edge_stuck += 1
        else:
            edge_stuck = 1 if pin_now else 0
        prev_edge_pin = pin_now

        if (DEAD_MODE and not cooldown and edge_stuck >= STUCK_FRAMES):
            rel_y = (cy - m.y) / m.h
            warped = False

            if cx <= m.x + EDGE_EPS:
                n = left_neighbor(mons, m)
                if n and not (n.y <= cy < n.y + n.h):
                    tx = n.x + n.w - 1 - EDGE_INSET
                    ty = int(round(n.y + rel_y * n.h))
                    ty = max(n.y, min(n.y + n.h - 1, ty))
                    hypr_send(f"dispatch movecursor {tx} {ty}")
                    log(f"deadzone L {m.name}->{n.name}: ({cx},{cy}) -> ({tx},{ty})")
                    last_warp = now
                    cx, cy, m = tx, ty, n
                    edge_stuck = 0
                    prev_edge_pin = None
                    warped = True

            if not warped and cx >= m.x + m.w - 1 - EDGE_EPS:
                n = right_neighbor(mons, m)
                if n and not (n.y <= cy < n.y + n.h):
                    tx = n.x + EDGE_INSET
                    ty = int(round(n.y + rel_y * n.h))
                    ty = max(n.y, min(n.y + n.h - 1, ty))
                    hypr_send(f"dispatch movecursor {tx} {ty}")
                    log(f"deadzone R {m.name}->{n.name}: ({cx},{cy}) -> ({tx},{ty})")
                    last_warp = now
                    cx, cy, m = tx, ty, n
                    edge_stuck = 0
                    prev_edge_pin = None
                    warped = True

            # 3) inf-canvas: user-defined edge teleport for any of 4 edges.
            # only fires when the natural neighbor logic above didn't handle
            # it, so it's a strict fallback to the standard hyprland topology.
            if not warped and INF_CANVAS:
                edge = at_edge(m, cx, cy)
                if edge:
                    dest = INF_CANVAS.get((m.name, edge))
                    if dest:
                        n = find_monitor_by_name(mons, dest[0])
                        if n:
                            rel = perp_rel(m, cx, cy, edge)
                            tx, ty = edge_target(n, dest[1], rel)
                            hypr_send(f"dispatch movecursor {tx} {ty}")
                            log(f"inf-canvas {m.name}:{edge}->"
                                f"{n.name}:{dest[1]}: ({cx},{cy}) -> "
                                f"({tx},{ty})")
                            last_warp = now
                            cx, cy, m = tx, ty, n
                            edge_stuck = 0
                            prev_edge_pin = None

        prev_mon = m
        prev_rel_y = (cy - m.y) / m.h


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        pass
